#include "../src/resource.h"
#include <windows.h>

/////////////////////////////////////////////////////////////////////////////
// Icons
/////////////////////////////////////////////////////////////////////////////

IDI_CURSOROVERLAY     ICON    "cursor.ico"
IDI_SMALL             ICON    "cursor_small.ico"

/////////////////////////////////////////////////////////////////////////////
// Binary Resources
/////////////////////////////////////////////////////////////////////////////

FONT_PROMPT           RCDATA  "promptfont.ttf"

/////////////////////////////////////////////////////////////////////////////
// Dialogs
/////////////////////////////////////////////////////////////////////////////

IDD_SAVE_CURSOR DIALOGEX 0, 0, 430, 170
STYLE DS_SETFONT | WS_POPUP
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Name this cursor position:", IDC_STATIC_SAVE_NAME, 15, 12, 200, 12
    EDITTEXT        IDC_EDIT_NAME, 15, 26, 400, 18, ES_AUTOHSCROLL
    LTEXT           "Coordinates:", IDC_STATIC_SAVE_COORD_LABEL, 15, 55, 80, 12
    LTEXT           "X: 0   Y: 0", IDC_STATIC_COORDS, 15, 70, 250, 14,
                    SS_NOPREFIX | SS_LEFTNOWORDWRAP
    LTEXT           "Type the name, press Enter, then type one command key.",
                    IDC_STATIC_SAVE_HINT, 15, 92, 400, 20
    DEFPUSHBUTTON   "&OK", IDOK, -200, -200, 1, 1
    PUSHBUTTON      "&Add Another", IDC_BTN_ADD_ANOTHER_CURSOR, -200, -200, 1, 1
    PUSHBUTTON      "Save + &Click", IDC_BTN_ADD_CLICK_CURSOR, -200, -200, 1, 1
    PUSHBUTTON      "&Cancel", IDCANCEL, -200, -200, 1, 1
END

IDD_RECORD_KEYS DIALOGEX 0, 0, 620, 358
STYLE DS_SETFONT | WS_POPUP
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Key Sequence Name:", IDC_STATIC_SEQ_NAME, 15, 12, 120, 12
    EDITTEXT        IDC_EDIT_SEQ_NAME, 15, 28, 282, 20, ES_AUTOHSCROLL
    LTEXT           "Step delay (ms):", IDC_STATIC_SEQ_DELAY, 313, 12, 92, 12
    EDITTEXT        IDC_EDIT_DELAY, 313, 28, 72, 20, ES_NUMBER | ES_AUTOHSCROLL
    LTEXT           "Recorded flow", IDC_STATIC_RECORDED_FLOW, 15, 58, 120, 12
    LISTBOX         IDC_LIST_KEYS, 15, 75, 290, 184,
                    LBS_NOINTEGRALHEIGHT | LBS_EXTENDEDSEL | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Typed / paste block", IDC_STATIC_PASTE_BLOCK, 318, 58, 150, 12
    EDITTEXT        IDC_EDIT_PASTE_TEXT, 318, 75, 287, 132,
                    ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Status:", IDC_STATIC_RECORD_STATUS_LABEL, 318, 216, 42, 12
    LTEXT           "Click 'Capture Key' then press your key(s).", IDC_STATIC_STATUS,
                    363, 216, 238, 36, SS_NOPREFIX
    PUSHBUTTON      "&Capture Key", IDC_BTN_CAPTURE, -200, -200, 1, 1
    PUSHBUTTON      "&Add Step", IDC_BTN_ADD_STEP, -200, -200, 1, 1
    PUSHBUTTON      "&Manual Input", IDC_BTN_MANUAL, -200, -200, 1, 1
    PUSHBUTTON      "Add &Another Key", IDC_BTN_ADD_ANOTHER_KEY, -200, -200, 1, 1
    PUSHBUTTON      "Add &Text/Paste", IDC_BTN_ADD_PASTE, -200, -200, 1, 1
    DEFPUSHBUTTON   "&OK", IDOK, -200, -200, 1, 1
    PUSHBUTTON      "&Cancel", IDCANCEL, -200, -200, 1, 1
END

IDD_MANUAL_KEYS DIALOGEX 0, 0, 430, 260
STYLE DS_SETFONT | DS_CENTER | WS_POPUP
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Step:", IDC_STATIC, 15, 12, 30, 12
    LTEXT           "Step 1", IDC_STATIC_STEP_NUM, 50, 12, 200, 12
    LTEXT           "Category:", IDC_STATIC, 15, 34, 58, 12
    COMBOBOX        IDC_COMBO_KEY_CATEGORY, 80, 32, 250, 180,
                    CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Select keys (up to 3 for combo):", IDC_STATIC, 15, 64, 200, 12
    LTEXT           "Key 1:", IDC_STATIC, 15, 84, 35, 12
    COMBOBOX        IDC_COMBO_KEY1, 80, 82, 180, 200, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Key 2:", IDC_STATIC, 15, 110, 35, 12
    COMBOBOX        IDC_COMBO_KEY2, 80, 108, 180, 200, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Key 3:", IDC_STATIC, 15, 136, 35, 12
    COMBOBOX        IDC_COMBO_KEY3, 80, 134, 180, 200, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Pick a category first, then add a key or combo step.",
                    IDC_STATIC, 282, 82, 126, 42, SS_NOPREFIX
    LTEXT           "Mouse, numpad, navigation, function, toggles, and symbols stay out of each other's way.",
                    IDC_STATIC, 282, 126, 126, 62, SS_NOPREFIX
    PUSHBUTTON      "&Add to Step", IDC_BTN_ADD_KEY, 15, 190, 92, 24
    PUSHBUTTON      "Add &Step + Next", IDC_BTN_ADD_STEP_MANUAL, 117, 190, 118, 24
    DEFPUSHBUTTON   "&Done", IDOK, 245, 225, 75, 22
    PUSHBUTTON      "&Cancel", IDCANCEL, 335, 225, 75, 22
END

IDD_CIRCLE_PLACER DIALOGEX 0, 0, 470, 238
STYLE DS_SETFONT | WS_POPUP
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Distance in Px", IDC_STATIC_CIRCLE_PROMPT, 15, 14, 430, 14,
                    SS_NOPREFIX | SS_LEFTNOWORDWRAP
    EDITTEXT        IDC_EDIT_CIRCLE_VALUE, 15, 34, 440, 20, ES_AUTOHSCROLL
    LTEXT           "Examples: 316 radius, -20i+20j pixel offset, or 316 @ -2i+2j scaled direction.",
                    IDC_STATIC_CIRCLE_HINT, 15, 62, 440, 28, SS_NOPREFIX
    LTEXT           "Enter a distance to draw a circle. Press Enter to continue.",
                    IDC_STATIC_CIRCLE_STATUS, 15, 98, 440, 44, SS_NOPREFIX
    PUSHBUTTON      "&Z Move Cursor", IDC_BTN_CIRCLE_MOVE_NOW, 15, 154, 125, 24
    PUSHBUTTON      "&X Append Coordinate", IDC_BTN_CIRCLE_APPEND_COORD, 150, 154, 140, 24
    PUSHBUTTON      "&C Circle From Here", IDC_BTN_CIRCLE_NEXT_CIRCLE, 300, 154, 120, 24
    PUSHBUTTON      "&V ZoneMake", IDC_BTN_CIRCLE_ZONE_ACTION, 15, 184, 125, 24
    DEFPUSHBUTTON   "&Enter", IDOK, 300, 198, 70, 24
    PUSHBUTTON      "&Cancel", IDCANCEL, 385, 198, 70, 24
END

IDD_CLICK_ACTION DIALOGEX 0, 0, 430, 118
STYLE DS_SETFONT | WS_POPUP
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Manual click", IDC_STATIC_CLICK_PROMPT, 15, 12, 400, 14,
                    SS_NOPREFIX | SS_LEFTNOWORDWRAP
    EDITTEXT        IDC_EDIT_CLICK_VALUE, 15, 32, 400, 20, ES_AUTOHSCROLL
    LTEXT           "Enter clicks now. Z holds down. X releases. C writes delayed click JSON.",
                    IDC_STATIC_CLICK_HINT, 15, 60, 400, 18, SS_NOPREFIX
    LTEXT           "Moving the mouse closes this HUD.", IDC_STATIC_CLICK_STATUS,
                    15, 82, 400, 18, SS_NOPREFIX
    DEFPUSHBUTTON   "&Enter", IDOK, -200, -200, 1, 1
    PUSHBUTTON      "&Cancel", IDCANCEL, -200, -200, 1, 1
END

IDD_VIEW_TOGGLES DIALOGEX 0, 0, 430, 118
STYLE DS_SETFONT | WS_POPUP
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Display toggles", IDC_STATIC_VIEW_PROMPT, 15, 12, 400, 14,
                    SS_NOPREFIX | SS_LEFTNOWORDWRAP
    EDITTEXT        IDC_EDIT_VIEW_VALUE, 15, 32, 400, 20, ES_AUTOHSCROLL
    LTEXT           "Z crosshair | X gridlines",
                    IDC_STATIC_VIEW_HINT, 15, 60, 400, 18, SS_NOPREFIX
    LTEXT           "Type one command key. Esc cancels.", IDC_STATIC_VIEW_STATUS,
                    15, 82, 400, 18, SS_NOPREFIX
    DEFPUSHBUTTON   "&Enter", IDOK, -200, -200, 1, 1
    PUSHBUTTON      "&Cancel", IDCANCEL, -200, -200, 1, 1
END

IDD_PASTE_BUFFERS DIALOGEX 0, 0, 430, 118
STYLE DS_SETFONT | WS_POPUP
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Paste buffers", IDC_STATIC_PASTE_BUFFER_PROMPT, 15, 12, 400, 14,
                    SS_NOPREFIX | SS_LEFTNOWORDWRAP
    EDITTEXT        IDC_EDIT_PASTE_BUFFER_VALUE, 15, 32, 400, 20,
                    ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_VSCROLL
    LTEXT           "Z/X/C/V edit buffers | B paste one",
                    IDC_STATIC_PASTE_BUFFER_HINT, 15, 60, 400, 18, SS_NOPREFIX
    LTEXT           "Type one command key. Esc cancels.", IDC_STATIC_PASTE_BUFFER_STATUS,
                    15, 82, 400, 18, SS_NOPREFIX
    DEFPUSHBUTTON   "&Enter", IDOK, -200, -200, 1, 1
    PUSHBUTTON      "&Cancel", IDCANCEL, -200, -200, 1, 1
END

IDD_REGISTRY_HUB DIALOGEX 0, 0, 760, 500
STYLE DS_SETFONT | WS_POPUP
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Registry Hub", IDC_STATIC_REGISTRY_HUB_PROMPT, 15, 12, 720, 14,
                    SS_NOPREFIX | SS_LEFTNOWORDWRAP
    EDITTEXT        IDC_EDIT_REGISTRY_HUB_VALUE, 15, 32, 730, 390,
                    ES_MULTILINE | ES_AUTOVSCROLL | ES_WANTRETURN | WS_VSCROLL
    LTEXT           "Z script | P play | E export path | I import path | H help | R registry | X/C/G aliases | A/S/D/F vars | N zones | 3/4/5 points",
                    IDC_STATIC_REGISTRY_HUB_HINT, 15, 432, 730, 26, SS_NOPREFIX
    LTEXT           "Escape closes and preserves state.",
                    IDC_STATIC_REGISTRY_HUB_STATUS, 15, 462, 730, 24, SS_NOPREFIX
    PUSHBUTTON      "Clear", IDC_BTN_REGISTRY_HUB_CLEAR, -200, -200, 1, 1
    PUSHBUTTON      "Export", IDC_BTN_REGISTRY_HUB_EXPORT, -200, -200, 1, 1
    PUSHBUTTON      "Import", IDC_BTN_REGISTRY_HUB_IMPORT, -200, -200, 1, 1
    PUSHBUTTON      "Save Schts", IDC_BTN_REGISTRY_HUB_SAVE_SCHTS, -200, -200, 1, 1
    DEFPUSHBUTTON   "&Enter", IDOK, -200, -200, 1, 1
    PUSHBUTTON      "&Cancel", IDCANCEL, -200, -200, 1, 1
END

/////////////////////////////////////////////////////////////////////////////
// Version
/////////////////////////////////////////////////////////////////////////////

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 1,0,0,0
 PRODUCTVERSION 1,0,0,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "CursorOverlay"
            VALUE "FileDescription", "Cursor Coordinate Overlay with Crosshairs"
            VALUE "FileVersion", "1.0.0.0"
            VALUE "InternalName", "CursorOverlay.exe"
            VALUE "LegalCopyright", "Open Source"
            VALUE "OriginalFilename", "CursorOverlay.exe"
            VALUE "ProductName", "CursorOverlay"
            VALUE "ProductVersion", "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
