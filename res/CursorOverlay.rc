#include "../src/resource.h"
#include <windows.h>

/////////////////////////////////////////////////////////////////////////////
// Icons
/////////////////////////////////////////////////////////////////////////////

IDI_CURSOROVERLAY     ICON    "cursor.ico"
IDI_SMALL             ICON    "cursor_small.ico"

/////////////////////////////////////////////////////////////////////////////
// Binary Resources
/////////////////////////////////////////////////////////////////////////////

FONT_PROMPT           RCDATA  "promptfont.ttf"

/////////////////////////////////////////////////////////////////////////////
// Dialogs
/////////////////////////////////////////////////////////////////////////////

IDD_SAVE_CURSOR DIALOGEX 0, 0, 340, 170
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Save Cursor Position"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Name this cursor position:", IDC_STATIC, 15, 12, 200, 12
    EDITTEXT        IDC_EDIT_NAME, 15, 26, 310, 18, ES_AUTOHSCROLL
    LTEXT           "Coordinates:", IDC_STATIC, 15, 55, 80, 12
    LTEXT           "X: 0   Y: 0", IDC_STATIC_COORDS, 15, 70, 250, 14,
                    SS_NOPREFIX | SS_LEFTNOWORDWRAP
    LTEXT           "Click 'Add Another' to add more points to this entry.",
                    IDC_STATIC, 15, 92, 310, 20
    DEFPUSHBUTTON   "&OK", IDOK, 75, 135, 70, 22
    PUSHBUTTON      "&Add Another", IDC_BTN_ADD_ANOTHER_CURSOR, 155, 135, 80, 22
    PUSHBUTTON      "&Cancel", IDCANCEL, 245, 135, 70, 22
END

IDD_RECORD_KEYS DIALOGEX 0, 0, 420, 310
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Record Key Sequence"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Key Sequence Name:", IDC_STATIC, 15, 12, 120, 12
    EDITTEXT        IDC_EDIT_SEQ_NAME, 15, 26, 390, 18, ES_AUTOHSCROLL
    GROUPBOX        "Recorded Keys", IDC_STATIC, 15, 50, 390, 125
    LISTBOX         IDC_LIST_KEYS, 25, 64, 370, 105,
                    LBS_NOINTEGRALHEIGHT | LBS_EXTENDEDSEL | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Status:", IDC_STATIC, 15, 182, 35, 12
    LTEXT           "Click 'Capture Key' then press your key(s).", IDC_STATIC_STATUS,
                    55, 182, 350, 20
    LTEXT           "Step delay (ms):", IDC_STATIC, 15, 210, 90, 12
    EDITTEXT        IDC_EDIT_DELAY, 110, 208, 60, 16, ES_NUMBER | ES_AUTOHSCROLL
    LTEXT           "(default: 200)", IDC_STATIC, 180, 210, 80, 12
    PUSHBUTTON      "&Capture Key", IDC_BTN_CAPTURE, 15, 240, 80, 24
    PUSHBUTTON      "&Add Step", IDC_BTN_ADD_STEP, 105, 240, 70, 24
    PUSHBUTTON      "&Manual Input", IDC_BTN_MANUAL, 185, 240, 80, 24
    PUSHBUTTON      "Add &Another Key", IDC_BTN_ADD_ANOTHER_KEY, 275, 240, 95, 24
    DEFPUSHBUTTON   "&OK", IDOK, 240, 280, 75, 22
    PUSHBUTTON      "&Cancel", IDCANCEL, 330, 280, 75, 22
END

IDD_MANUAL_KEYS DIALOGEX 0, 0, 390, 240
STYLE DS_SETFONT | DS_MODALFRAME | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Manual Key Input"
FONT 9, "Segoe UI", 400, 0, 0x1
BEGIN
    LTEXT           "Step:", IDC_STATIC, 15, 12, 30, 12
    LTEXT           "Step 1", IDC_STATIC_STEP_NUM, 50, 12, 200, 12
    LTEXT           "Select keys (up to 3 for combo):", IDC_STATIC, 15, 32, 200, 12
    LTEXT           "Key 1:", IDC_STATIC, 15, 52, 35, 12
    COMBOBOX        IDC_COMBO_KEY1, 55, 50, 130, 200, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Key 2:", IDC_STATIC, 15, 76, 35, 12
    COMBOBOX        IDC_COMBO_KEY2, 55, 74, 130, 200, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Key 3:", IDC_STATIC, 15, 100, 35, 12
    COMBOBOX        IDC_COMBO_KEY3, 55, 98, 130, 200, CBS_DROPDOWNLIST | WS_VSCROLL | WS_TABSTOP
    LTEXT           "Valid key names:", IDC_STATIC, 210, 32, 120, 12
    LTEXT           "A-Z, 0-9, F1-F12", IDC_STATIC, 210, 48, 160, 12
    LTEXT           "CONTROL_LEFT/RIGHT", IDC_STATIC, 210, 63, 160, 12
    LTEXT           "SHIFT_LEFT/RIGHT", IDC_STATIC, 210, 78, 160, 12
    LTEXT           "ALT_LEFT, ALT_GR", IDC_STATIC, 210, 93, 160, 12
    LTEXT           "SPACEBAR, ENTER, TAB", IDC_STATIC, 210, 108, 160, 12
    LTEXT           "NUMPAD_0-9, ARROWS", IDC_STATIC, 210, 123, 160, 12
    LTEXT           "See README for full list", IDC_STATIC, 210, 138, 160, 12
    PUSHBUTTON      "&Add to Step", IDC_BTN_ADD_KEY, 15, 165, 85, 24
    PUSHBUTTON      "Add &Step + Next", IDC_BTN_ADD_STEP_MANUAL, 110, 165, 110, 24
    DEFPUSHBUTTON   "&Done", IDOK, 200, 205, 75, 22
    PUSHBUTTON      "&Cancel", IDCANCEL, 290, 205, 75, 22
END

/////////////////////////////////////////////////////////////////////////////
// Version
/////////////////////////////////////////////////////////////////////////////

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 1,0,0,0
 PRODUCTVERSION 1,0,0,0
 FILEFLAGSMASK 0x3fL
 FILEFLAGS 0x0L
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "CursorOverlay"
            VALUE "FileDescription", "Cursor Coordinate Overlay with Crosshairs"
            VALUE "FileVersion", "1.0.0.0"
            VALUE "InternalName", "CursorOverlay.exe"
            VALUE "LegalCopyright", "Open Source"
            VALUE "OriginalFilename", "CursorOverlay.exe"
            VALUE "ProductName", "CursorOverlay"
            VALUE "ProductVersion", "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END
